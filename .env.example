# --- Database ---
DATABASE_URL=postgresql://user:password@host:5432/revive_marketing

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# --- Internal service-to-service key (Pulse CRM <-> this API) ---
# Same pattern as pulse_key_portalapi / pulse_key_portalsecret already in use.
INTERNAL_API_KEY=change-me

# --- Public website lead-intake key (POST /leads) ---
# Held server-side by the Netlify lead proxy; never exposed in the browser.
# REQUIRED for /leads to work: must be a dedicated, long random string
# (>= 16 chars, not a placeholder). There is intentionally NO fallback to
# INTERNAL_API_KEY, so the public endpoint can't reuse the internal service key.
LEADS_INGEST_KEY=change-me-to-a-long-random-string

# --- Pulse CRM backend (for pulling contacts / loan pipeline data) ---
PULSE_API_BASE=https://revive-loan-portal-api.up.railway.app
PULSE_INTERNAL_KEY=

# --- Twilio (Voice + SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_FROM_NUMBER=
# 10DLC campaign must be registered in the Twilio console before real SMS volume goes out.
TWILIO_MESSAGING_SERVICE_SID=

# --- SendGrid (Email blast) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=marketing@myrevivecapital.com
SENDGRID_FROM_NAME=Revive Capital

# --- Compliance defaults ---
QUIET_HOURS_START=08:00
QUIET_HOURS_END=21:00
DEFAULT_TIMEZONE=America/Los_Angeles
